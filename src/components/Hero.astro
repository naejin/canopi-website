---
import { t, type Locale } from '../i18n/utils';
import { CANOPI_DOWNLOADS, CANOPI_RELEASES_URL } from '../data/release';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const CANOPI_WEB_URL = 'https://web.projectcanopi.com/';

const installers = [
  {
    key: 'linux-appimage',
    labelKey: 'edition.installer.linuxAppImage',
    href: CANOPI_DOWNLOADS.linuxAppImage,
  },
  {
    key: 'linux-deb',
    labelKey: 'edition.installer.linuxDeb',
    href: CANOPI_DOWNLOADS.linuxDeb,
  },
  {
    key: 'macos-apple',
    labelKey: 'edition.installer.macApple',
    href: CANOPI_DOWNLOADS.macAppleSiliconDmg,
  },
  {
    key: 'macos-intel',
    labelKey: 'edition.installer.macIntel',
    href: CANOPI_DOWNLOADS.macIntelDmg,
  },
  {
    key: 'windows-exe',
    labelKey: 'edition.installer.windowsExe',
    href: CANOPI_DOWNLOADS.windowsSetupExe,
  },
  {
    key: 'windows-msi',
    labelKey: 'edition.installer.windowsMsi',
    href: CANOPI_DOWNLOADS.windowsMsi,
  },
];

---

<section class="hero">
  <div class="hero-shell">
    <h1 class="hero-headline">
      {t('hero.headlineTop', lang)}
      <span class="hero-headline-accent">{t('hero.headlineAccent', lang)}</span>
    </h1>

    <div class="hero-lower">
      <figure class="demo-panel">
        <video
          src="/demo-canopi-720.mp4"
          poster="/screenshot-light.png"
          class="demo-video"
          autoplay
          muted
          loop
          playsinline
          preload="metadata"
          aria-label={t('hero.videoLabel', lang)}
        ></video>
      </figure>

      <section class="edition-dock" aria-label={t('edition.label', lang)}>
        <div class="edition-dock-inner">
          <h2 class="edition-title">{t('edition.title', lang)}</h2>
          <div class="edition-actions">
            <a
              href={CANOPI_RELEASES_URL}
              class="edition-button edition-button-primary"
              data-desktop-primary
              data-default-label={t('edition.desktop.defaultChoice', lang)}
              data-linux-href={CANOPI_DOWNLOADS.linuxAppImage}
              data-linux-label={t('edition.installer.linuxAppImage', lang)}
              data-macos-arm-href={CANOPI_DOWNLOADS.macAppleSiliconDmg}
              data-macos-arm-label={t('edition.installer.macApple', lang)}
              data-macos-x64-href={CANOPI_DOWNLOADS.macIntelDmg}
              data-macos-x64-label={t('edition.installer.macIntel', lang)}
              data-windows-href={CANOPI_DOWNLOADS.windowsSetupExe}
              data-windows-label={t('edition.installer.windowsExe', lang)}
            >
              <span class="edition-button-title">{t('edition.desktop.cta', lang)}</span>
              <span class="edition-button-note" data-desktop-primary-label>{t('edition.desktop.defaultChoice', lang)}</span>
            </a>

            <a href={CANOPI_WEB_URL} class="edition-button edition-button-secondary">
              <span class="edition-button-title">{t('edition.web.cta', lang)}</span>
              <span class="edition-button-note">{t('edition.web.note', lang)}</span>
            </a>
          </div>

          <details class="installer-details">
            <summary>{t('edition.desktop.moreChoices', lang)}</summary>
            <div class="installer-list">
              {installers.map((installer) => (
                <a href={installer.href} class="installer-link" data-installer={installer.key}>
                  {t(installer.labelKey, lang)}
                </a>
              ))}
              <a href={CANOPI_RELEASES_URL} class="installer-link">{t('download.allReleases', lang)}</a>
            </div>
          </details>
        </div>
      </section>
    </div>
  </div>

  <script>
    (async function initDesktopDownload() {
      const button = document.querySelector<HTMLAnchorElement>('[data-desktop-primary]');
      const label = document.querySelector<HTMLElement>('[data-desktop-primary-label]');
      if (!button || !label) return;

      type Detected = { href?: string; label?: string } | null;

      async function detect(): Promise<Detected> {
        const uad = (navigator as any).userAgentData;
        if (uad && typeof uad.getHighEntropyValues === 'function') {
          try {
            const data = await uad.getHighEntropyValues(['architecture', 'platform']);
            const platform = String(data.platform || uad.platform || '').toLowerCase();
            const arch = String(data.architecture || '').toLowerCase();
            if (platform.includes('windows')) {
              return { href: button.dataset.windowsHref, label: button.dataset.windowsLabel };
            }
            if (platform.includes('mac') || platform === 'macos') {
              const isArm = arch.includes('arm');
              return isArm
                ? { href: button.dataset.macosArmHref, label: button.dataset.macosArmLabel }
                : { href: button.dataset.macosX64Href, label: button.dataset.macosX64Label };
            }
            if (platform.includes('linux')) {
              return { href: button.dataset.linuxHref, label: button.dataset.linuxLabel };
            }
          } catch {
            // Some browsers expose userAgentData but deny high-entropy fields.
          }
        }

        const ua = navigator.userAgent || '';
        if (/Android|iPhone|iPad|iPod/i.test(ua)) return null;
        if (/Windows NT/i.test(ua)) return { href: button.dataset.windowsHref, label: button.dataset.windowsLabel };
        if (/Mac OS X|Macintosh/i.test(ua)) return { href: button.dataset.macosArmHref, label: button.dataset.macosArmLabel };
        if (/Linux|X11|CrOS/i.test(ua)) return { href: button.dataset.linuxHref, label: button.dataset.linuxLabel };
        return null;
      }

      const result = await detect();
      if (!result?.href || !result.label) return;
      button.href = result.href;
      label.textContent = result.label;
      button.setAttribute('data-detected', '');
    })();
  </script>

</section>

<style>
  .hero {
    position: relative;
    background: var(--canvas-bg);
    overflow: hidden;
    --t-head: 260ms;
    --t-video: 360ms;
    --t-editions: 560ms;
  }

  .hero-shell {
    max-width: var(--content-width);
    margin: 0 auto;
    padding-left: var(--space-6);
    padding-right: var(--space-6);
    padding-top: var(--space-16);
    padding-bottom: var(--space-16);
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-text);
    letter-spacing: 0;
    max-width: 920px;
    margin: 0 0 var(--space-10);
  }

  .hero-headline-accent {
    color: var(--color-primary);
    display: inline;
  }

  .hero-lower {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
    align-items: stretch;
  }

  .demo-panel {
    margin: 0;
    background: #1C1915;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-xl);
    overflow: hidden;
  }

  .demo-video {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 16 / 9;
    object-fit: contain;
    object-position: center;
  }

  .edition-dock {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    min-width: 0;
  }

  .edition-dock-inner {
    display: grid;
    align-content: start;
    gap: var(--space-4);
    min-height: 100%;
    padding: var(--space-6);
  }

  .edition-title {
    max-width: 14ch;
    font-family: var(--font-display);
    font-size: var(--text-2xl);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-text);
    letter-spacing: 0;
  }

  .edition-actions {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }

  .edition-button {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    min-height: 64px;
    padding: var(--space-4);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-md);
    transition:
      background var(--transition-fast),
      border-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-normal);
  }

  .edition-button:hover,
  .edition-button:focus-visible {
    transform: translateY(-1px);
  }

  .edition-button-primary {
    background: var(--color-primary);
    color: var(--color-primary-contrast);
    border-color: transparent;
  }

  .edition-button-primary:hover,
  .edition-button-primary:focus-visible {
    background: var(--color-primary-hover);
  }

  .edition-button-secondary {
    background: var(--canvas-bg);
    color: var(--color-text);
  }

  .edition-button-secondary:hover,
  .edition-button-secondary:focus-visible {
    border-color: var(--color-primary);
    background: var(--color-control-hover);
  }

  .edition-button-title {
    font-family: var(--font-body);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: var(--leading-snug);
    letter-spacing: 0;
    min-width: 0;
    white-space: nowrap;
  }

  .edition-button-note {
    font-size: var(--text-sm);
    font-weight: 600;
    text-align: right;
    opacity: 0.78;
  }

  .installer-details {
    width: 100%;
    border: 0;
    overflow: hidden;
  }

  .installer-details summary {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: var(--space-2);
    min-height: 36px;
    padding: 0;
    color: var(--color-text-muted);
    cursor: pointer;
    font-size: var(--text-sm);
    font-weight: 600;
    list-style: none;
  }

  .installer-details summary::-webkit-details-marker {
    display: none;
  }

  .installer-details summary::after {
    content: "+";
    color: var(--color-primary);
    font-size: var(--text-lg);
    line-height: 1;
  }

  .installer-details[open] summary::after {
    content: "-";
  }

  .installer-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-2);
    padding-top: var(--space-3);
  }

  .installer-link {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: var(--space-2) var(--space-3);
    color: var(--color-text);
    font-size: var(--text-sm);
    font-weight: 600;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--canvas-bg);
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast),
      background var(--transition-fast);
  }

  .installer-link:hover,
  .installer-link:focus-visible {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: var(--color-control-hover);
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 639px) {
    .hero-shell {
      padding: var(--space-12) var(--space-6);
    }

    .hero-headline {
      font-size: var(--text-3xl);
      margin-bottom: var(--space-8);
    }

    .edition-dock-inner {
      padding: var(--space-4);
    }

    .edition-button {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--space-1);
      min-height: 0;
      padding: var(--space-4);
    }

    .edition-button-note {
      text-align: left;
    }
  }

  @media (min-width: 640px) {
    .installer-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (min-width: 960px) {
    .hero-shell {
      padding-top: var(--space-20);
      padding-bottom: var(--space-20);
    }

    .hero-headline {
      font-size: var(--text-5xl);
      line-height: 1.08;
    }

    .hero-lower {
      grid-template-columns: minmax(0, 1fr) 360px;
    }
  }

  @media (min-width: 1200px) {
    .hero-headline {
      font-size: 5rem;
      max-width: 1020px;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-headline {
      animation: fadeUp 600ms var(--transition-slow) both;
      animation-delay: var(--t-head);
    }

    .demo-panel {
      animation: fadeUp 700ms var(--transition-slow) both;
      animation-delay: var(--t-video);
    }

    .edition-dock {
      animation: fadeUp 600ms var(--transition-slow) both;
      animation-delay: var(--t-editions);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero *,
    .hero *::before,
    .hero *::after {
      animation-duration: 1ms !important;
      animation-delay: 0ms !important;
      transition: none !important;
    }
  }
</style>
