---
import { t, type Locale } from '../i18n/utils';
interface Props { lang: Locale; }
const { lang } = Astro.props;

const VERSION = '0.4.0';
const BASE = `https://github.com/naejin/canopi/releases/download/v${VERSION}`;

const platforms = [
  { name: 'Linux', formats: '.deb (amd64)', icon: 'linux', href: `${BASE}/Canopi_${VERSION}_amd64.deb` },
  { name: 'macOS', formats: '.dmg (Apple Silicon)', icon: 'macos', href: `${BASE}/Canopi_${VERSION}_aarch64.dmg`, alt: { label: 'Intel Mac', href: `${BASE}/Canopi_${VERSION}_x64.dmg` } },
  { name: 'Windows', formats: '.exe (x64)', icon: 'windows', href: `${BASE}/Canopi_${VERSION}_x64-setup.exe` },
];
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      {t('hero.badge', lang)}
    </div>

    <h1 class="hero-headline">
      {t('hero.headlineTop', lang)}<br />
      <span class="hero-headline-accent">{t('hero.headlineAccent', lang)}</span>
    </h1>

    <p class="hero-subtext">
      {t('hero.subtext', lang)}
    </p>

    <div class="hero-screenshot">
      <img
        src="/screenshot-light.png"
        alt="Canopi app — design canvas with plant database"
        class="screenshot screenshot-light"
        width="2299"
        height="1614"
        loading="eager"
      />
      <img
        src="/screenshot-dark.png"
        alt="Canopi app — design canvas with plant database"
        class="screenshot screenshot-dark"
        width="2299"
        height="1614"
        loading="eager"
      />
    </div>

    <div class="hero-downloads">
      {platforms.map((platform) => (
        <div class="dl-wrap">
          <a href={platform.href} class="dl-card" aria-label={t('download.forPlatform', lang, { platform: platform.name })}>
            <div class="dl-icon">
              {platform.icon === 'linux' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M19 18.616v.534c0 .469-.38.85-.85.85h-.3c-.469 0-.85-.38-.85-.85v-.084c-1.054.15-2.403.284-4 .317v.617c0 .469-.38.85-.85.85h-.3c-.469 0-.85-.38-.85-.85v-.617c-1.597-.033-2.946-.167-4-.317v.084c0 .469-.38.85-.85.85h-.3c-.469 0-.85-.38-.85-.85v-.534c-1.164-.36-1.9-.816-1.9-1.316 0-.263.18-.516.5-.744v-3.556c0-3.866 3.134-7 7-7h.4c3.866 0 7 3.134 7 7v3.556c.32.228.5.481.5.744 0 .5-.736.956-1.9 1.316zM10 10a1 1 0 100-2 1 1 0 000 2zm4 0a1 1 0 100-2 1 1 0 000 2zm-4.5 3c0 .828 1.119 1.5 2.5 1.5s2.5-.672 2.5-1.5h-5z"/>
                </svg>
              )}
              {platform.icon === 'macos' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z"/>
                </svg>
              )}
              {platform.icon === 'windows' && (
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M0 3.449L9.75 2.1v9.451H0m10.949-9.602L24 0v11.4H10.949M0 12.6h9.75v9.451L0 20.699M10.949 12.6H24V24l-12.9-1.801"/>
                </svg>
              )}
            </div>
            <div class="dl-info">
              <span class="dl-name">{platform.name}</span>
              <span class="dl-format">{platform.formats}</span>
            </div>
          </a>
          {'alt' in platform && platform.alt && (
            <a href={platform.alt.href} class="dl-alt">{platform.alt.label} (.dmg)</a>
          )}
        </div>
      ))}
    </div>

    <p class="hero-releases">
      <a href="https://github.com/naejin/canopi/releases" target="_blank" rel="noopener noreferrer">
        {t('download.allReleases', lang)}
      </a>
    </p>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">{t('hero.statPlantsValue', lang)}</span>
        <span class="stat-label">{t('hero.statPlants', lang)}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">{t('hero.statLangsValue', lang)}</span>
        <span class="stat-label">{t('hero.statLangs', lang)}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">{t('hero.statPlatformsValue', lang)}</span>
        <span class="stat-label">{t('hero.statPlatforms', lang)}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">{t('hero.statLicenseValue', lang)}</span>
        <span class="stat-label">{t('hero.statLicense', lang)}</span>
      </div>
    </div>
  </div>

  <div class="hero-border" aria-hidden="true">
    <svg viewBox="0 0 1200 24" preserveAspectRatio="none" fill="none" stroke="var(--color-border-strong)" stroke-width="1">
      <path d="M0 12 Q 150 0, 300 12 T 600 12 T 900 12 T 1200 12" />
      <path d="M0 12 Q 150 24, 300 12 T 600 12 T 900 12 T 1200 12" />
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--canvas-bg);
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-24) var(--space-6) var(--space-20);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-10);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 100ms;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-success);
    animation: pulse 2s ease-in-out infinite;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-8);
    letter-spacing: -0.02em;
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 200ms;
  }

  .hero-headline-accent {
    color: var(--color-primary);
    font-style: italic;
  }

  /* ── Screenshot ── */
  .hero-screenshot {
    width: 100%;
    max-width: 900px;
    margin-bottom: var(--space-12);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 400ms;
  }

  .screenshot {
    width: 100%;
    height: auto;
    border-radius: var(--radius-xl);
    border: 1px solid var(--color-border);
    box-shadow: var(--shadow-xl);
  }

  .screenshot-dark { display: none; }
  .screenshot-light { display: block; }

  [data-theme="dark"] .screenshot-dark { display: block; }
  [data-theme="dark"] .screenshot-light { display: none; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .screenshot-dark { display: block; }
    :root:not([data-theme="light"]) .screenshot-light { display: none; }
  }

  .hero-subtext {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 640px;
    margin-bottom: var(--space-12);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 350ms;
  }

  /* ── Download cards ── */
  .hero-downloads {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-3);
    width: 100%;
    max-width: 560px;
    margin-bottom: var(--space-4);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 500ms;
  }

  .dl-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-6) var(--space-4);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    transition: all var(--transition-normal);
  }

  .dl-card:hover {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md), 0 0 0 3px var(--color-primary-bg);
    transform: translateY(-2px);
  }

  .dl-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-md);
    background: var(--color-primary-bg);
    color: var(--color-primary);
  }

  .dl-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .dl-name {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
  }

  .dl-format {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .dl-alt {
    display: block;
    text-align: center;
    padding-top: var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .dl-alt:hover {
    color: var(--color-primary);
  }

  .hero-releases {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-12);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 550ms;
  }

  .hero-releases a {
    color: var(--color-primary);
    transition: color var(--transition-fast);
  }

  .hero-releases a:hover {
    color: var(--color-primary-hover);
  }

  /* ── Stats ── */
  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 650ms;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text);
  }

  .stat-label {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--color-border-strong);
  }

  /* ── Decorative border ── */
  .hero-border {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 24px;
    opacity: 0.4;
  }

  .hero-border svg {
    width: 100%;
    height: 100%;
  }

  /* ── Animations ── */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  /* ── Responsive ── */
  @media (max-width: 639px) {
    .hero-inner { padding: var(--space-16) var(--space-6) var(--space-12); }
    .hero-headline { font-size: var(--text-3xl); }
    .hero-subtext { font-size: var(--text-base); }
    .hero-downloads { grid-template-columns: 1fr; max-width: 280px; }
    .dl-card { flex-direction: row; padding: var(--space-3) var(--space-4); }
    .dl-info { align-items: flex-start; }
    .hero-stats { flex-wrap: wrap; justify-content: center; gap: var(--space-4); }
    .stat-divider { display: none; }
    .stat { min-width: 80px; }
  }

  @media (min-width: 960px) {
    .hero-headline { font-size: var(--text-5xl); }
    .hero-subtext { font-size: var(--text-lg); }
  }
</style>
