---
import { t, type Locale } from '../i18n/utils';
interface Props { lang: Locale; }
const { lang } = Astro.props;
---

<section class="hero">
  <div class="hero-inner">
    <div class="hero-badge">
      <span class="badge-dot"></span>
      {t('hero.badge', lang)}
    </div>

    <h1 class="hero-headline">
      {t('hero.headlineTop', lang)}<br />
      <span class="hero-headline-accent">{t('hero.headlineAccent', lang)}</span>
    </h1>

    <p class="hero-subtext">
      {t('hero.subtext', lang)}
    </p>

    <div class="hero-actions">
      <a href="#download" class="btn btn-primary">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        {t('hero.downloadBtn', lang)}
      </a>
    </div>

    <div class="hero-stats">
      <div class="stat">
        <span class="stat-value">{t('hero.statPlantsValue', lang)}</span>
        <span class="stat-label">{t('hero.statPlants', lang)}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">{t('hero.statLangsValue', lang)}</span>
        <span class="stat-label">{t('hero.statLangs', lang)}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">{t('hero.statPlatformsValue', lang)}</span>
        <span class="stat-label">{t('hero.statPlatforms', lang)}</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat">
        <span class="stat-value">{t('hero.statLicenseValue', lang)}</span>
        <span class="stat-label">{t('hero.statLicense', lang)}</span>
      </div>
    </div>
  </div>

  <div class="hero-border" aria-hidden="true">
    <svg viewBox="0 0 1200 24" preserveAspectRatio="none" fill="none" stroke="var(--color-border-strong)" stroke-width="1">
      <path d="M0 12 Q 150 0, 300 12 T 600 12 T 900 12 T 1200 12" />
      <path d="M0 12 Q 150 24, 300 12 T 600 12 T 900 12 T 1200 12" />
    </svg>
  </div>
</section>

<style>
  .hero {
    position: relative;
    background: var(--canvas-bg);
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: var(--space-24) var(--space-6) var(--space-20);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-4);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-full);
    margin-bottom: var(--space-10);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 100ms;
  }

  .badge-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-success);
    animation: pulse 2s ease-in-out infinite;
  }

  .hero-headline {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-text);
    margin-bottom: var(--space-8);
    letter-spacing: -0.02em;
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 200ms;
  }

  .hero-headline-accent {
    color: var(--color-primary);
    font-style: italic;
  }

  .hero-subtext {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 640px;
    margin-bottom: var(--space-10);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 350ms;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    justify-content: center;
    margin-bottom: var(--space-16);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 500ms;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-base);
    font-weight: 600;
    border-radius: var(--radius-md);
    transition: all var(--transition-normal);
    white-space: nowrap;
  }

  .btn-primary {
    background: var(--color-primary);
    color: var(--color-primary-contrast);
    box-shadow: var(--shadow-md), 0 0 0 0 rgba(160, 107, 31, 0);
  }

  .btn-primary:hover {
    background: var(--color-primary-hover);
    box-shadow: var(--shadow-lg), 0 0 0 4px var(--color-primary-bg);
    transform: translateY(-1px);
  }

  .btn-secondary {
    background: var(--color-surface);
    color: var(--color-text);
    border: 1px solid var(--color-border-strong);
    box-shadow: var(--shadow-sm);
  }

  .btn-secondary:hover {
    background: var(--color-surface-alt);
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  .hero-stats {
    display: flex;
    align-items: center;
    gap: var(--space-6);
    animation: fadeUp 600ms var(--transition-slow) both;
    animation-delay: 650ms;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-1);
  }

  .stat-value {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    color: var(--color-text);
  }

  .stat-label {
    font-size: var(--text-sm);
    font-weight: 400;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 32px;
    background: var(--color-border-strong);
  }

  .hero-border {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 24px;
    opacity: 0.4;
  }

  .hero-border svg {
    width: 100%;
    height: 100%;
  }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  @media (max-width: 639px) {
    .hero-inner { padding: var(--space-16) var(--space-6) var(--space-12); }
    .hero-headline { font-size: var(--text-3xl); }
    .hero-subtext { font-size: var(--text-base); }
    .hero-actions { flex-direction: column; width: 100%; max-width: 320px; }
    .btn { justify-content: center; width: 100%; }
    .hero-stats { flex-wrap: wrap; justify-content: center; gap: var(--space-4); }
    .stat-divider { display: none; }
    .stat { min-width: 80px; }
  }

  @media (min-width: 960px) {
    .hero-headline { font-size: var(--text-5xl); }
    .hero-subtext { font-size: var(--text-lg); }
  }
</style>
