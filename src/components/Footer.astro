---
import { t, localizedUrl, type Locale } from '../i18n/utils';
import { CANOPI_RELEASES_URL } from '../data/release';
interface Props { lang: Locale; }
const { lang } = Astro.props;
const CANOPI_WEB_URL = 'https://web.projectcanopi.com/';
const discordUrl = lang === 'fr'
  ? 'https://discord.gg/7wq9HsBdsc'
  : 'https://discord.gg/k7bsyjD9b8';
---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href={localizedUrl('/', lang)} class="footer-logo" aria-label={t('header.home', lang)}>
        <img src="/canopi-logo.svg" alt="" width="24" height="24" />
        <span>Canopi</span>
      </a>
      <span class="footer-license">{t('footer.license', lang)}</span>
    </div>

    <nav class="footer-links" aria-label="Footer">
      <a href={CANOPI_WEB_URL}>Canopi Web</a>
      <a href={CANOPI_RELEASES_URL}>{t('download.allReleases', lang)}</a>
      <a
        href={discordUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        Discord
      </a>
      <a
        href="https://github.com/naejin/canopi"
        target="_blank"
        rel="noopener noreferrer"
        class="footer-github"
        aria-label={t('header.github', lang)}
      >
        <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </nav>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
    padding: var(--space-10) var(--space-6);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-6);
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .footer-brand {
    display: grid;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    width: max-content;
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--color-text);
    transition: opacity var(--transition-fast);
  }

  .footer-logo:hover { opacity: 0.8; }
  .footer-logo img { width: 24px; height: 24px; border-radius: 2px; }
  .footer-license { font-weight: 400; }

  .footer-links {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .footer-links a {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    transition:
      color var(--transition-fast),
      background var(--transition-fast);
  }

  .footer-links a:hover,
  .footer-links a:focus-visible {
    color: var(--color-primary);
    background: var(--color-control-hover);
  }

  .footer-github {
    display: flex;
    align-items: center;
    padding: var(--space-2);
  }

  @media (max-width: 639px) {
    .footer-inner {
      align-items: flex-start;
      gap: var(--space-5);
    }

    .footer-links {
      justify-content: flex-start;
    }
  }
</style>
