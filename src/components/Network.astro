---
import { t, type Locale } from '../i18n/utils';
interface Props { lang: Locale; }
const { lang } = Astro.props;

const countries = [
  {
    key: 'france',
    labelKey: 'network.country.france',
    organisations: [
      {
        name: 'Destination Syntropie',
        url: 'https://destinationsyntropie.org/',
        logo: '/network/destination-syntropie.png',
      },
      {
        name: 'La Vache Heureuse',
        url: 'https://www.lvh-france.com/',
        logo: '/network/la-vache-heureuse.png',
      },
      {
        name: 'Ver de Terre Production',
        url: 'https://www.verdeterreprod.fr/',
        logo: '/network/ver-de-terre-production.png',
      },
      {
        name: 'Maraîchage Sol Vivant',
        url: 'https://www.maraichagesolvivant.fr/',
        logo: '/network/maraichage-sol-vivant.png',
        tone: 'light',
      },
      {
        name: 'Centre for Living Agroecology and food Systems',
        url: 'https://www.centreagroecologie.fr/',
        logo: '/network/centre-living-agroecology.png',
      },
    ],
  },
  {
    key: 'brazil',
    labelKey: 'network.country.brazil',
    organisations: [
      {
        name: 'Agenda Gotsch',
        url: 'https://agendagotsch.com/en/',
        logo: '/network/agenda-gotsch.jpg',
      },
    ],
  },
];
---

<section class="network" aria-labelledby="network-title">
  <div class="network-inner">
    <div class="network-header">
      <span class="section-label">{t('network.label', lang)}</span>
      <h2 id="network-title" class="section-title">{t('network.title', lang)}</h2>
    </div>

    <div class="country-stack">
      {countries.map((country) => (
        <section class="country-group" aria-labelledby={`network-${country.key}`}>
          <h3 id={`network-${country.key}`} class="country-title">{t(country.labelKey, lang)}</h3>
          <div class="org-grid">
            {country.organisations.map((org) => (
              <a href={org.url} class="org-card" target="_blank" rel="noopener noreferrer">
                <span class:list={['org-logo-well', { 'org-logo-well-light': org.tone === 'light' }]}>
                  <img src={org.logo} alt="" class="org-logo" loading="lazy" decoding="async" />
                </span>
                <span class="org-name">{org.name}</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</section>

<style>
  .network {
    background: var(--color-bg);
    padding: var(--space-20) var(--space-6);
  }

  .network-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .network-header {
    text-align: center;
    margin-bottom: var(--space-12);
  }

  .section-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    line-height: var(--leading-snug);
    color: var(--color-text);
    letter-spacing: 0;
  }

  .country-stack {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .country-title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 600;
    letter-spacing: 0;
    color: var(--color-text);
    margin-bottom: var(--space-5);
  }

  .country-title::after {
    content: "";
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  .org-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .org-card {
    display: grid;
    grid-template-columns: 112px 1fr;
    align-items: center;
    min-height: 112px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal), transform var(--transition-normal);
  }

  .org-card:hover,
  .org-card:focus-visible {
    border-color: var(--color-primary);
    box-shadow: var(--shadow-md), 0 0 0 3px var(--color-primary-bg);
    transform: translateY(-2px);
  }

  .org-logo-well {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: stretch;
    background: #1C1915;
    padding: var(--space-4);
  }

  .org-logo-well-light {
    background: var(--color-bg);
  }

  .org-logo {
    display: block;
    width: 100%;
    max-width: 88px;
    max-height: 72px;
    object-fit: contain;
  }

  .org-name {
    padding: var(--space-4) var(--space-5);
    color: var(--color-text);
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: var(--leading-snug);
  }

  @media (max-width: 639px) {
    .network {
      padding: var(--space-14) var(--space-6);
    }

    .org-card {
      grid-template-columns: 96px 1fr;
      min-height: 100px;
    }

    .org-name {
      font-size: var(--text-base);
      padding: var(--space-3) var(--space-4);
    }
  }

  @media (min-width: 640px) {
    .org-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 960px) {
    .section-title { font-size: var(--text-4xl); }
    .org-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
