---
import { t, type Locale } from '../i18n/utils';
interface Props { lang: Locale; }
const { lang } = Astro.props;

const countries = [
  {
    key: 'france',
    labelKey: 'network.country.france',
    organisations: [
      {
        name: 'Destination Syntropie',
        url: 'https://destinationsyntropie.org/',
        logo: '/network/destination-syntropie.png',
      },
      {
        name: 'La Vache Heureuse',
        url: 'https://www.lvh-france.com/',
        logo: '/network/la-vache-heureuse.png',
      },
      {
        name: 'Ver de Terre Production',
        url: 'https://www.verdeterreprod.fr/',
        logo: '/network/ver-de-terre-production.png',
      },
      {
        name: 'Maraîchage Sol Vivant',
        url: 'https://www.maraichagesolvivant.fr/',
        logo: '/network/maraichage-sol-vivant.png',
        tone: 'light',
      },
      {
        name: 'Centre for Living Agroecology and food Systems',
        url: 'https://www.centreagroecologie.fr/',
        logo: '/network/centre-living-agroecology.png',
      },
    ],
  },
  {
    key: 'brazil',
    labelKey: 'network.country.brazil',
    organisations: [
      {
        name: 'Agenda Gotsch',
        url: 'https://agendagotsch.com/en/',
        logo: '/network/agenda-gotsch.jpg',
      },
    ],
  },
];
---

<section class="network" aria-labelledby="network-title">
  <div class="network-inner">
    <div class="network-header">
      <h2 id="network-title" class="section-title">{t('network.title', lang)}</h2>
    </div>

    <div class="network-ledger">
      {countries.map((country) => (
        <section class="country-group" aria-labelledby={`network-${country.key}`}>
          <header class="country-index">
            <span class="country-count">{String(country.organisations.length).padStart(2, '0')}</span>
            <h3 id={`network-${country.key}`} class="country-title">{t(country.labelKey, lang)}</h3>
          </header>
          <div class="org-list">
            {country.organisations.map((org) => (
              <a href={org.url} class="org-row" target="_blank" rel="noopener noreferrer">
                <span class:list={['org-logo-well', { 'org-logo-well-light': org.tone === 'light' }]}>
                  <img src={org.logo} alt="" class="org-logo" loading="lazy" decoding="async" />
                </span>
                <span class="org-name">{org.name}</span>
                <span class="org-arrow" aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</section>

<style>
  .network {
    background: var(--color-bg);
    padding: var(--space-16) var(--space-6);
  }

  .network-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .network-header {
    margin-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-3);
  }

  .section-title {
    font-family: var(--font-body);
    font-size: var(--text-xl);
    font-weight: 600;
    line-height: var(--leading-snug);
    color: var(--color-text);
    letter-spacing: 0;
  }

  .network-ledger {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-surface);
  }

  .country-group {
    display: grid;
    grid-template-columns: 1fr;
    border-top: 1px solid var(--color-border);
  }

  .country-group:first-child {
    border-top: 0;
  }

  .country-index {
    display: grid;
    grid-template-columns: 64px 1fr;
    align-items: stretch;
    border-bottom: 1px solid var(--color-border);
    background: var(--color-bg);
  }

  .country-title {
    display: flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    padding: var(--space-3) var(--space-4);
  }

  .country-count {
    display: flex;
    align-items: center;
    justify-content: center;
    border-right: 1px solid var(--color-border);
    color: var(--color-primary);
    font-size: var(--text-sm);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .org-list {
    display: grid;
    grid-template-columns: 1fr;
  }

  .org-row {
    display: grid;
    grid-template-columns: 96px minmax(0, 1fr) 42px;
    align-items: center;
    min-height: 86px;
    background: var(--canvas-bg);
    border-top: 1px solid var(--color-border);
    overflow: hidden;
    transition: background var(--transition-fast), color var(--transition-fast);
  }

  .org-row:first-child {
    border-top: 0;
  }

  .org-row:hover,
  .org-row:focus-visible {
    background: var(--color-control-hover);
    color: var(--color-primary);
  }

  .org-logo-well {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: stretch;
    background: #1C1915;
    padding: var(--space-3);
    border-right: 1px solid var(--color-border);
  }

  .org-logo-well-light {
    background: var(--color-bg);
  }

  .org-logo {
    display: block;
    width: 100%;
    max-width: 76px;
    max-height: 60px;
    object-fit: contain;
  }

  .org-name {
    padding: var(--space-3) var(--space-4);
    color: currentColor;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    line-height: var(--leading-snug);
    min-width: 0;
  }

  .org-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: stretch;
    border-left: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  @media (max-width: 639px) {
    .network {
      padding: var(--space-12) var(--space-6);
    }

    .country-index {
      grid-template-columns: 52px 1fr;
    }

    .org-row {
      grid-template-columns: 82px minmax(0, 1fr) 34px;
      min-height: 88px;
    }

    .org-name {
      font-size: var(--text-base);
      padding: var(--space-3) var(--space-4);
    }
  }

  @media (min-width: 960px) {
    .section-title { font-size: var(--text-2xl); }

    .country-group {
      grid-template-columns: 180px 1fr;
    }

    .country-index {
      grid-template-columns: 1fr;
      grid-template-rows: 64px 1fr;
      border-bottom: 0;
      border-right: 1px solid var(--color-border);
    }

    .country-count {
      border-right: 0;
      border-bottom: 1px solid var(--color-border);
    }

    .country-title {
      align-items: flex-start;
      padding: var(--space-4);
    }

    .org-list {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .org-row {
      border-left: 1px solid var(--color-border);
    }

    .org-row:nth-child(2n + 1) {
      border-left: 0;
    }

    .org-row:nth-child(-n + 2) {
      border-top: 0;
    }
  }
</style>
