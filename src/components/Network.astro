---
import { t, type Locale } from '../i18n/utils';
interface Props { lang: Locale; }
const { lang } = Astro.props;

const countries = [
  {
    key: 'france',
    labelKey: 'network.country.france',
    organisations: [
      {
        name: 'Destination Syntropie',
        url: 'https://destinationsyntropie.org/',
        logo: '/network/destination-syntropie.png',
      },
      {
        name: 'La Vache Heureuse',
        url: 'https://www.lvh-france.com/',
        logo: '/network/la-vache-heureuse.png',
      },
      {
        name: 'Ver de Terre Production',
        url: 'https://www.verdeterreprod.fr/',
        logo: '/network/ver-de-terre-production.png',
      },
      {
        name: 'Maraîchage Sol Vivant',
        url: 'https://www.maraichagesolvivant.fr/',
        logo: '/network/maraichage-sol-vivant.png',
        tone: 'light',
      },
      {
        name: 'Centre for Living Agroecology and food Systems',
        url: 'https://www.centreagroecologie.fr/',
        logo: '/network/centre-living-agroecology.png',
      },
    ],
  },
  {
    key: 'brazil',
    labelKey: 'network.country.brazil',
    organisations: [
      {
        name: 'Agenda Gotsch',
        url: 'https://agendagotsch.com/en/',
        logo: '/network/agenda-gotsch.jpg',
      },
    ],
  },
];
---

<section class="network" aria-labelledby="network-title">
  <div class="network-inner">
    <header class="network-header">
      <h2 id="network-title" class="section-title">{t('network.title', lang)}</h2>
    </header>

    <div class="network-atlas">
      {countries.map((country, index) => (
        <section class="country-panel" aria-labelledby={`network-${country.key}`}>
          <header class="country-cardinal">
            <span class="country-number">{String(index + 1).padStart(2, '0')}</span>
            <h3 id={`network-${country.key}`} class="country-title">{t(country.labelKey, lang)}</h3>
            <span class="country-total">{String(country.organisations.length).padStart(2, '0')}</span>
          </header>

          <div class="org-cluster">
            {country.organisations.map((org) => (
              <a href={org.url} class="org-node" target="_blank" rel="noopener noreferrer">
                <span class:list={['org-logo-frame', { 'org-logo-frame-light': org.tone === 'light' }]}>
                  <img src={org.logo} alt="" class="org-logo" loading="lazy" decoding="async" />
                </span>
                <span class="org-name">{org.name}</span>
                <span class="org-arrow" aria-hidden="true">↗</span>
              </a>
            ))}
          </div>
        </section>
      ))}
    </div>
  </div>
</section>

<style>
  .network {
    background: var(--canvas-bg);
    padding: var(--space-20) var(--space-6);
  }

  .network-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .network-header {
    margin-bottom: var(--space-8);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    line-height: var(--leading-tight);
    color: var(--color-text);
    letter-spacing: 0;
  }

  .network-atlas {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .country-panel {
    display: grid;
    grid-template-columns: 1fr;
    overflow: hidden;
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
  }

  .country-cardinal {
    display: grid;
    grid-template-columns: 52px minmax(0, 1fr) 52px;
    align-items: center;
    background: #1C1915;
    color: #E8E2D8;
  }

  .country-title {
    display: flex;
    align-items: center;
    min-width: 0;
    padding: var(--space-4);
    border-left: 1px solid rgba(232, 226, 216, 0.18);
    border-right: 1px solid rgba(232, 226, 216, 0.18);
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 400;
    line-height: var(--leading-snug);
    color: currentColor;
  }

  .country-number,
  .country-total {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 64px;
    color: #C89B4A;
    font-size: var(--text-sm);
    font-weight: 600;
    font-variant-numeric: tabular-nums;
  }

  .org-cluster {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
    padding: var(--space-4);
    background:
      linear-gradient(135deg, rgba(160, 107, 31, 0.08), transparent 56%),
      var(--color-surface);
  }

  .org-node {
    display: grid;
    grid-template-columns: 82px minmax(0, 1fr) 38px;
    align-items: center;
    min-height: 78px;
    background: var(--canvas-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition:
      border-color var(--transition-fast),
      background var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-normal);
  }

  .org-node:hover,
  .org-node:focus-visible {
    background: var(--color-control-hover);
    border-color: var(--color-primary);
    color: var(--color-primary);
    transform: translateY(-1px);
  }

  .org-logo-frame {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: stretch;
    background: #1C1915;
    padding: var(--space-2);
    border-right: 1px solid var(--color-border);
  }

  .org-logo-frame-light {
    background: var(--color-bg);
  }

  .org-logo {
    display: block;
    width: 100%;
    max-width: 62px;
    max-height: 52px;
    object-fit: contain;
  }

  .org-name {
    padding: var(--space-3) var(--space-4);
    color: currentColor;
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: 600;
    line-height: var(--leading-snug);
    min-width: 0;
  }

  .org-arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: stretch;
    border-left: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-weight: 600;
  }

  @media (max-width: 639px) {
    .network {
      padding: var(--space-12) var(--space-6);
    }

    .section-title {
      font-size: var(--text-2xl);
    }

    .country-cardinal {
      grid-template-columns: 44px minmax(0, 1fr) 44px;
    }

    .country-number,
    .country-total {
      min-height: 56px;
    }

    .country-title {
      font-size: var(--text-lg);
      padding: var(--space-3);
    }

    .org-cluster {
      padding: var(--space-3);
    }

    .org-node {
      grid-template-columns: 72px minmax(0, 1fr) 34px;
      min-height: 76px;
    }

    .org-name {
      font-size: var(--text-base);
      padding: var(--space-3) var(--space-4);
    }
  }

  @media (min-width: 960px) {
    .network-atlas {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      align-items: start;
    }

    .country-panel:first-child {
      grid-column: span 2;
    }

    .country-panel:first-child .org-cluster {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .org-cluster {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
</style>
