---
import { t, type Locale } from '../i18n/utils';
interface Props { lang: Locale; }
const { lang } = Astro.props;

const features = [
  {
    icon: 'leaf',
    titleKey: 'features.plants.title',
    descKey: 'features.plants.desc',
  },
  {
    icon: 'zones',
    titleKey: 'features.zones.title',
    descKey: 'features.zones.desc',
  },
  {
    icon: 'stamp',
    titleKey: 'features.stamp.title',
    descKey: 'features.stamp.desc',
  },
  {
    icon: 'spacing',
    titleKey: 'features.spacing.title',
    descKey: 'features.spacing.desc',
  },
  {
    icon: 'report',
    titleKey: 'features.reports.title',
    descKey: 'features.reports.desc',
  },
  {
    icon: 'workspace',
    titleKey: 'features.workspace.title',
    descKey: 'features.workspace.desc',
  },
];
---

<section id="features" class="features">
  <div class="features-inner">
    <div class="features-header">
      <h2 class="section-title">{t('features.title', lang)}</h2>
      <p class="section-desc">{t('features.desc', lang)}</p>
    </div>

    <div class="features-grid">
      {features.map((feature, i) => (
        <div class="feature-card" style={`animation-delay: ${200 + i * 120}ms`}>
          <div class="feature-icon">
            {feature.icon === 'leaf' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"/>
                <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
              </svg>
            )}
            {feature.icon === 'zones' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="8" height="7" rx="1.5"/>
                <ellipse cx="16.5" cy="7.5" rx="4" ry="3"/>
                <path d="M6 20h7l4-5-3-3H7l-3 4Z"/>
                <path d="M4 14l9 6"/>
              </svg>
            )}
            {feature.icon === 'stamp' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M9 3h6l1 7H8Z"/>
                <path d="M7 10h10l2 5H5Z"/>
                <path d="M5 18h14"/>
                <path d="M8 21h2"/>
                <path d="M14 21h2"/>
              </svg>
            )}
            {feature.icon === 'spacing' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="6" cy="12" r="2.5"/>
                <circle cx="18" cy="12" r="2.5"/>
                <path d="M8.5 12h7"/>
                <path d="M10 9l-2.5 3L10 15"/>
                <path d="M14 9l2.5 3L14 15"/>
                <path d="M6 5v2"/>
                <path d="M18 5v2"/>
                <path d="M6 17v2"/>
                <path d="M18 17v2"/>
              </svg>
            )}
            {feature.icon === 'report' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M6 3h8l4 4v14H6Z"/>
                <path d="M14 3v5h5"/>
                <path d="M9 13h6"/>
                <path d="M9 17h4"/>
                <path d="M10 9h1"/>
              </svg>
            )}
            {feature.icon === 'workspace' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="16" rx="2"/>
                <path d="M3 9h18"/>
                <path d="M8 9v11"/>
                <path d="M13 14h5"/>
                <path d="M15 12l-2 2 2 2"/>
                <path d="M17 16l2-2-2-2"/>
              </svg>
            )}
          </div>
          <h3 class="feature-title">{t(feature.titleKey, lang)}</h3>
          <p class="feature-desc">{t(feature.descKey, lang)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--color-bg);
    padding: var(--space-20) var(--space-6);
  }

  .features-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    line-height: var(--leading-snug);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    letter-spacing: -0.01em;
  }

  .section-desc {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    transition: box-shadow var(--transition-normal), transform var(--transition-normal);
  }

  .feature-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--color-primary-bg);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: var(--leading-snug);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .feature-desc {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  @media (min-width: 640px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .features-grid { grid-template-columns: repeat(3, 1fr); }
    .section-title { font-size: var(--text-4xl); }
  }
</style>
