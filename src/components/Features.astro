---
import { t, type Locale } from '../i18n/utils';
interface Props { lang: Locale; }
const { lang } = Astro.props;

const features = [
  {
    icon: 'leaf',
    titleKey: 'features.plants.title',
    descKey: 'features.plants.desc',
  },
  {
    icon: 'canvas',
    titleKey: 'features.canvas.title',
    descKey: 'features.canvas.desc',
  },
  {
    icon: 'share',
    titleKey: 'features.share.title',
    descKey: 'features.share.desc',
  },
  {
    icon: 'globe',
    titleKey: 'features.platform.title',
    descKey: 'features.platform.desc',
  },
];
---

<section id="features" class="features">
  <div class="features-inner">
    <div class="features-header">
      <h2 class="section-title">{t('features.title', lang)}</h2>
      <p class="section-desc">{t('features.desc', lang)}</p>
    </div>

    <div class="features-grid">
      {features.map((feature, i) => (
        <div class="feature-card" style={`animation-delay: ${200 + i * 120}ms`}>
          <div class="feature-icon">
            {feature.icon === 'leaf' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M11 20A7 7 0 0 1 9.8 6.9C15.5 4.9 17 3.5 19 2c1 2 2 4.5 2 8 0 5.5-4.78 10-10 10Z"/>
                <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"/>
              </svg>
            )}
            {feature.icon === 'canvas' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                <path d="M18.375 2.625a1 1 0 0 1 3 3l-9.013 9.014a2 2 0 0 1-.853.505l-2.873.84a.5.5 0 0 1-.62-.62l.84-2.873a2 2 0 0 1 .506-.852z"/>
              </svg>
            )}
            {feature.icon === 'share' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/>
                <polyline points="16 6 12 2 8 6"/>
                <line x1="12" y1="2" x2="12" y2="15"/>
              </svg>
            )}
            {feature.icon === 'globe' && (
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <path d="M12 2a14.5 14.5 0 0 0 0 20 14.5 14.5 0 0 0 0-20"/>
                <path d="M2 12h20"/>
              </svg>
            )}
          </div>
          <h3 class="feature-title">{t(feature.titleKey, lang)}</h3>
          <p class="feature-desc">{t(feature.descKey, lang)}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .features {
    background: var(--color-bg);
    padding: var(--space-20) var(--space-6);
  }

  .features-inner {
    max-width: var(--content-width);
    margin: 0 auto;
  }

  .features-header {
    text-align: center;
    margin-bottom: var(--space-16);
  }

  .section-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    margin-bottom: var(--space-3);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: var(--text-3xl);
    font-weight: 400;
    line-height: var(--leading-snug);
    color: var(--color-text);
    margin-bottom: var(--space-4);
    letter-spacing: -0.01em;
  }

  .section-desc {
    font-size: var(--text-md);
    line-height: var(--leading-relaxed);
    color: var(--color-text-muted);
    max-width: 560px;
    margin: 0 auto;
  }

  .features-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: var(--space-8);
    transition: box-shadow var(--transition-normal), transform var(--transition-normal);
  }

  .feature-card:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: var(--radius-md);
    background: var(--color-primary-bg);
    color: var(--color-primary);
    margin-bottom: var(--space-6);
  }

  .feature-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: 600;
    line-height: var(--leading-snug);
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .feature-desc {
    font-size: var(--text-base);
    line-height: var(--leading-normal);
    color: var(--color-text-muted);
  }

  @media (min-width: 640px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (min-width: 960px) {
    .features-grid { grid-template-columns: repeat(4, 1fr); }
    .section-title { font-size: var(--text-4xl); }
  }
</style>
