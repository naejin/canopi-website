---
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Features from '../../components/Features.astro';
import Footer from '../../components/Footer.astro';
import { t, locales, defaultLocale, isLocale, type Locale } from '../../i18n/utils';

export function getStaticPaths() {
  return locales
    .filter((l) => l !== defaultLocale)
    .map((lang) => ({ params: { lang } }));
}

const { lang: langParam } = Astro.params;
const lang = (isLocale(langParam) ? langParam : defaultLocale) as Locale;
---

<Base
  title={t('meta.title', lang)}
  description={t('meta.description', lang)}
  lang={lang}
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Features lang={lang} />
  </main>
  <Footer lang={lang} />
</Base>
